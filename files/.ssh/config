# First one wins - the first time we set an option it sticks.
Host valen lennier garibaldi vpn-router cotto
    User @home.user@
    # Uncomment this line to login to boxes that don't yet have our new keys
    # HostKeyAlgorithms=+ssh-rsa

Host jmeter maxdevcloud keycloak prod* load* qa* uat* selenium* norm*
    User @work.user@
    ForwardX11 yes
    ForwardX11Trusted yes

Host localhost 127.0.0.1
    User @local.user@
    # HostKeyAlgorithms=+ssh-rsa
    ForwardX11 yes
    ForwardX11Trusted yes

Host homelab kube*
    User root
    HostKeyAlgorithms=+ssh-rsa-cert-v01@openssh.com,ssh-rsa
    ServerAliveInterval 60
    XAuthLocation /usr/bin/xauth
    ForwardX11 no
    ForwardX11Trusted no

Host *
    User @local.user@
    #HostKeyAlgorithms=ssh-rsa-cert-v01@openssh.com,ssh-rsa
    ServerAliveInterval 60
    XAuthLocation /usr/bin/xauth
    ForwardX11 no
    ForwardX11Trusted no
    # prefer the ed25519 key to the rsa key.
    IdentityFile ~/.ssh/id_ed25519
    IdentityFile ~/.ssh/id_rsa


